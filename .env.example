# ─── Turso Database ───────────────────────────────────────────────────────────
# Lấy ở: https://app.turso.tech → tạo database → Connection Strings
DATABASE_URL=libsql://your-db-name-your-org.turso.io
DATABASE_AUTH_TOKEN=your_turso_auth_token

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your_random_secret_here

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Vercel sẽ tự thêm khi link Blob Store; cần có khi chạy local upload ảnh
BLOB_READ_WRITE_TOKEN=vercel_blob_read_write_token
