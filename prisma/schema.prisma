generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(uuid())
  code        String        @unique
  clientName  String
  instrument  String?
  panelType   String
  description String?
  status      String
  salesPerson String?
  appPerson   String?
  deadline    DateTime?
  createdAt   DateTime      @default(now())
  logs        ActivityLog[]
  projectLogs ProjectLog[]

  @@index([status])
  @@index([createdAt])
}

model ProjectLog {
  id          String   @id @default(uuid())
  note        String
  status      String
  updatedBy   String
  createdAt   DateTime @default(now())
  projectId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

model ActivityLog {
  id            String   @id @default(uuid())
  teamMember    String
  logDate       DateTime
  category      String
  durationHours Float
  description   String
  projectId     String?
  createdAt     DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([teamMember])
  @@index([category])
  @@index([logDate])
}

// --- Knowledge Base ---

model Article {
  id        String   @id @default(uuid())
  module    String   // illumina | vi-sinh | cepheid
  title     String
  category  String   @default("quy-trinh") // quy-trinh | huong-dan | troubleshooting | faq
  content   String
  tags      String   // comma-separated tags
  author    String
  attachmentUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  procedureShares ProcedureShare[]
  images    ArticleImage[]

  @@index([module])
  @@index([category])
}

model ArticleImage {
  id        String   @id @default(uuid())
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  articleId String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, sortOrder])
}

// --- Vi Sinh Module ---

model ErrorCode {
  id          String   @id @default(uuid())
  module      String   @default("vi-sinh") // illumina | vi-sinh | cepheid
  code        String   @unique
  instrument  String   // e.g. Vitek 2, MicroScan, NextSeq, etc.
  description String
  cause       String
  solution    String
  imageUrl    String?  // Hình minh họa lỗi hoặc cách xử lý
  severity    String   // low | medium | high | critical
  createdAt   DateTime @default(now())

  @@index([instrument])
  @@index([code])
  @@index([module])
}

model SupportCase {
  id          String   @id @default(uuid())
  module      String   // vi-sinh | cepheid | illumina
  caseDate    DateTime
  customer    String
  instrument  String
  issueType   String
  description String
  content     String?
  resolution  String
  handler     String
  status      String   // open | resolved | escalated
  imageUrl    String?  // Legacy single-image field kept for backward compatibility
  attachmentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      SupportCaseImage[]

  @@index([module])
  @@index([status])
  @@index([caseDate])
}

model SupportCaseImage {
  id            String      @id @default(uuid())
  imageUrl      String
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  supportCaseId String

  supportCase SupportCase @relation(fields: [supportCaseId], references: [id], onDelete: Cascade)

  @@index([supportCaseId, sortOrder])
}

model User {
  id           String          @id @default(uuid())
  fullName     String
  email        String          @unique
  passwordHash String
  role         String          @default("user") // admin | user
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  sessions     Session[]
  procedureShares ProcedureShare[] @relation("SharedByUser")

  @@index([role])
  @@index([isActive])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ProcedureShare {
  id            String              @id @default(uuid())
  token         String              @unique
  customerName  String
  customerEmail String?
  status        String              @default("pending") // pending | completed
  sharedAt      DateTime            @default(now())
  completedAt   DateTime?
  articleId     String
  sharedById    String?

  article   Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sharedBy  User?              @relation("SharedByUser", fields: [sharedById], references: [id], onDelete: SetNull)
  reactions ProcedureReaction[]

  @@index([articleId])
  @@index([sharedById])
  @@index([status])
}

model ProcedureReaction {
  id           String   @id @default(uuid())
  reactionType String   // like | heart
  createdAt    DateTime @default(now())
  shareId      String

  share ProcedureShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([shareId])
  @@index([reactionType])
}

// --- Content Feedback (like/dislike cho article, case, error-code) ---
model ContentFeedback {
  id          String   @id @default(uuid())
  contentType String   // article | case | error-code
  contentId   String
  userId      String   // user id hoặc anonymous session id
  reaction    String   // like | dislike
  comment     String?  // feedback comment tùy chọn
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contentType, contentId, userId])
  @@index([contentType, contentId])
  @@index([userId])
}
